# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
.svelte-kit/
build/
dist/

# Terraform
deploy/terraform/.terraform/
deploy/terraform/.terraform.lock.hcl
deploy/terraform/*.tfstate
deploy/terraform/*.tfstate.backup
deploy/terraform/terraform.tfvars
deploy/terraform/crash.log

# Python
__pycache__/
*.py[cod]
*.so
.venv/
venv/
*.egg-info/
.eggs/

# Audio / transcript artifacts
audio/
*.mp3
*.mp4
*.wav
*_transcript.txt
*_timestamped.txt
*_subtitles.srt

# Whisper model cache
~/.cache/huggingface/

# Env
.env
.env.local
.env.*.local

# Editor
.DS_Store
.idea/
*.swp
*.swo

# Bundled whisper weights (regenerated by scripts/predownload_model.py)
api/_models/
.env*
certs/

# Reference codebases kept for agents to mine (see .learnings/index.md) — the
# codebases themselves stay local-only, the curated index is tracked.
.learnings/*
!.learnings/index.md

# Rust / Tauri build output (regenerated by `cargo build` / `tauri build`)
src-tauri/target/
# Tauri auto-generates capability/ACL schemas at build time — not hand-authored
src-tauri/gen/

# PyInstaller sidecar build output (regenerated by scripts/build_sidecar.py;
# includes the bundled ffmpeg/ffprobe binaries fetched by scripts/fetch_ffmpeg.py).
# build/ and dist/ above already cover api/build, api/dist, and the repo-root
# dist/ PyInstaller produces; *.spec covers the auto-generated PyInstaller
# spec files (not hand-authored — regenerated on every build_sidecar.py run).
src-tauri/binaries/
*.spec

# Standalone Python venv used only for the sidecar build (separate from .venv/
# above, used for the build:sidecar pipeline specifically)
.venv-build/

# Claude Code: personal/machine-local permission overrides and runtime lock
# files — commands/ and skills/ under .claude/ are shared tool config and
# stay tracked.
.claude/settings.local.json
.claude/scheduled_tasks.lock